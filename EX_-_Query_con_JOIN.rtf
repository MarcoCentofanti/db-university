\cf0 \strokec2 6. Selezionare tutti i docenti che insegnano nel Dipartimento di Matematica (54)\
\
\cf3 \strokec2 SELECT DISTINCT teachers.id,\
       teachers.name,\
       teachers.surname\
FROM  teachers\
JOIN course_teacher\
ON teacher_id = teachers.id\
JOIN courses\
ON course_id = courses.id\
JOIN degrees\
ON degree_id = degrees.id\
JOIN departments\
ON department_id = departments.id\
WHERE departments.name = 'Dipartimento di Matematica'\cf0 \strokec2 \
\
