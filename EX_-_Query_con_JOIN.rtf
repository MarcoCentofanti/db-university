\cf0 \strokec2 3. Selezionare tutti i corsi in cui insegna Fulvio Amato (id=44)\
\
\pard\pardeftab720\partightenfactor0
\cf3 \strokec2 SELECT *\
FROM  courses\
INNER JOIN course_teacher \
ON course_id = courses.id\
INNER JOIN teachers\
ON teacher_id = teachers.id\
WHERE teacher_id = 44\
\
\cf0 \strokec2 4. Selezionare tutti gli studenti con i dati relativi al corso di laurea a cui sono iscritti e il relativo dipartimento, in ordine alfabetico per cognome e nome\
\
\cf3 \strokec2 SELECT *\
FROM  students\
INNER JOIN degrees \
ON degree_id = degrees.id\
INNER JOIN departments \
ON department_id = departments.id\
ORDER BY students.surname, students.name\cf0 \strokec2 \
\
5. Selezionare tutti i corsi di laurea con i relativi corsi e insegnanti\
\
\cf3 \strokec2 SELECT *\
FROM  degrees\
JOIN courses \
ON degree_id = degrees.id\
JOIN course_teacher\
ON course_id = courses.id\
\
